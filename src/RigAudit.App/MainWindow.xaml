<Window x:Class="RigAudit.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RigAudit.App.ViewModels"
        xmlns:conv="clr-namespace:RigAudit.App.Converters"
        Title="Rig Audit Pro" Height="700" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#FF1E1E2E">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Window.Resources>
        <conv:ViewStateToVisibilityConverter x:Key="ViewStateToVis" />
        <conv:SeverityToColorConverter x:Key="SeverityToColor" />
        <conv:SeverityToGlyphConverter x:Key="SeverityToGlyph" />

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF89B4FA" />
            <Setter Property="Margin" Value="0,12,0,6" />
        </Style>
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="#FF2A2D3A" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#FFA6ADC8" />
            <Setter Property="Width" Value="160" />
        </Style>
        <Style x:Key="FieldValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#FFCDD6F4" />
            <Setter Property="ToolTip" Value="Unknown means this value could not be detected on this system. Sensors may require vendor driver support." />
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#FF89B4FA" />
            <Setter Property="Foreground" Value="#FF1E1E2E" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="24,10" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <!-- HOME VIEW -->
        <Grid Visibility="{Binding CurrentView, Converter={StaticResource ViewStateToVis}, ConverterParameter=Home}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Rig Audit Pro"
                           FontSize="32" FontWeight="Bold"
                           Foreground="#FFCDD6F4"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8" />
                <TextBlock Text="Read-only PC configuration audit for gamers"
                           FontSize="14"
                           Foreground="#FFA6ADC8"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,32" />
                <Button Content="Run Scan"
                        Command="{Binding RunScanCommand}"
                        Style="{StaticResource ActionButton}"
                        HorizontalAlignment="Center"
                        Width="200" />
                <TextBlock Text="{Binding StatusText}"
                           FontSize="13"
                           Foreground="#FFA6ADC8"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0" />
            </StackPanel>
        </Grid>

        <!-- RESULTS VIEW -->
        <Grid Visibility="{Binding CurrentView, Converter={StaticResource ViewStateToVis}, ConverterParameter=Results}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="Scan Results"
                           FontSize="24" FontWeight="Bold"
                           Foreground="#FFCDD6F4"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding StatusText}"
                           FontSize="13"
                           Foreground="#FFA6ADC8"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0" />
            </StackPanel>

            <!-- Scrollable content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Unknown values indicate data could not be detected on this system. Sensor data may be unavailable depending on hardware and driver support."
                               FontSize="12"
                               Foreground="#FFA6ADC8"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10" />

                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="Machine" Style="{StaticResource SectionHeader}" Margin="0,0,0,6" />
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="Timestamp (UTC)" Style="{StaticResource FieldLabel}" />
                                <TextBlock Text="{Binding DisplayTimestampUtc}" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="Computer Name" Style="{StaticResource FieldLabel}" />
                                <TextBlock Text="{Binding DisplayComputerName}" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="Windows User" Style="{StaticResource FieldLabel}" />
                                <TextBlock Text="{Binding DisplayWindowsUser}" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="Operating System" Style="{StaticResource SectionHeader}" Margin="0,0,0,6" />
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="Edition" Style="{StaticResource FieldLabel}" />
                                <TextBlock Text="{Binding DisplayWindowsEdition}" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="Version" Style="{StaticResource FieldLabel}" />
                                <TextBlock Text="{Binding DisplayWindowsVersion}" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="Build" Style="{StaticResource FieldLabel}" />
                                <TextBlock Text="{Binding DisplayWindowsBuild}" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="CPU" Style="{StaticResource SectionHeader}" Margin="0,0,0,6" />
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="Name" Style="{StaticResource FieldLabel}" />
                                <TextBlock Text="{Binding DisplayCpuName}" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="Cores" Style="{StaticResource FieldLabel}" />
                                <TextBlock Text="{Binding DisplayCpuCores}" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="GPU" Style="{StaticResource SectionHeader}" Margin="0,0,0,6" />
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="Name" Style="{StaticResource FieldLabel}" />
                                <TextBlock Text="{Binding DisplayGpuName}" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="Vendor" Style="{StaticResource FieldLabel}" />
                                <TextBlock Text="{Binding DisplayGpuVendor}" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="Driver Version" Style="{StaticResource FieldLabel}" />
                                <TextBlock Text="{Binding DisplayGpuDriver}" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Content="{Binding DriverSupportButtonText}"
                                        Command="{Binding OpenOfficialDriverPageCommand}"
                                        Style="{StaticResource ActionButton}"
                                        Width="260"
                                        Height="34"
                                        Padding="10,6"
                                        Background="#FF45475A"
                                        Foreground="#FFCDD6F4" />
                                <TextBlock Text="{Binding DriverSupportHintText}"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="#FFA6ADC8"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Width="300" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="Memory" Style="{StaticResource SectionHeader}" Margin="0,0,0,6" />
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="Total Physical" Style="{StaticResource FieldLabel}" />
                                <TextBlock Text="{Binding DisplayTotalMemory}" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="Configured Speed" Style="{StaticResource FieldLabel}" />
                                <TextBlock Text="{Binding DisplayMemorySpeed}" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="Power" Style="{StaticResource SectionHeader}" Margin="0,0,0,6" />
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="Active Plan" Style="{StaticResource FieldLabel}" />
                                <TextBlock Text="{Binding DisplayPowerPlan}" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="Active Plan GUID" Style="{StaticResource FieldLabel}" />
                                <TextBlock Text="{Binding DisplayPowerPlanGuid}" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="Sensors" Style="{StaticResource SectionHeader}" Margin="0,0,0,6" />
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="CPU Temperature" Style="{StaticResource FieldLabel}" />
                                <TextBlock Text="{Binding DisplayCpuTemp}" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="GPU Temperature" Style="{StaticResource FieldLabel}" />
                                <TextBlock Text="{Binding DisplayGpuTemp}" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="CPU Load" Style="{StaticResource FieldLabel}" />
                                <TextBlock Text="{Binding DisplayCpuLoad}" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="GPU Load" Style="{StaticResource FieldLabel}" />
                                <TextBlock Text="{Binding DisplayGpuLoad}" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="Storage" Style="{StaticResource SectionHeader}" Margin="0,0,0,6" />
                            <ItemsControl ItemsSource="{Binding StorageDrives}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FF313244" CornerRadius="6" Padding="10" Margin="0,3">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="70" />
                                                    <ColumnDefinition Width="80" />
                                                    <ColumnDefinition Width="90" />
                                                    <ColumnDefinition Width="90" />
                                                    <ColumnDefinition Width="90" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding VolumeName, TargetNullValue=Unknown, FallbackValue=Unknown}" Foreground="#FFCDD6F4" FontSize="12" />
                                                <TextBlock Grid.Column="1" Text="{Binding IsSystemDrive, StringFormat=System: {0}}" Foreground="#FFA6ADC8" FontSize="12" />
                                                <TextBlock Grid.Column="2" Text="{Binding DriveKind, TargetNullValue=Unknown, FallbackValue=Unknown}" Foreground="#FFA6ADC8" FontSize="12" />
                                                <TextBlock Grid.Column="3" Text="{Binding TotalSizeGb, StringFormat={}{0:F1} GB}" Foreground="#FFA6ADC8" FontSize="12" />
                                                <TextBlock Grid.Column="4" Text="{Binding FreeSpaceGb, StringFormat={}{0:F1} GB}" Foreground="#FFA6ADC8" FontSize="12" />
                                                <TextBlock Grid.Column="5" Text="{Binding FreePercent, StringFormat={}{0:F1}%}" Foreground="#FFA6ADC8" FontSize="12" />
                                                <TextBlock Grid.Column="6" Text="{Binding SmartHealthStatus, TargetNullValue=Not supported, FallbackValue=Not supported}" Foreground="#FFA6ADC8" FontSize="12" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="SMART health is reported as Not supported when safe read-only status is unavailable."
                                       FontSize="12"
                                       Foreground="#FFA6ADC8"
                                       Margin="0,6,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="Devices" Style="{StaticResource SectionHeader}" Margin="0,0,0,6" />
                            <ItemsControl ItemsSource="{Binding DeviceInventory}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FF313244" CornerRadius="6" Padding="10" Margin="0,3">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="140" />
                                                    <ColumnDefinition Width="220" />
                                                    <ColumnDefinition Width="150" />
                                                    <ColumnDefinition Width="140" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Category, TargetNullValue=Unknown, FallbackValue=Unknown}" Foreground="#FFCDD6F4" FontSize="12" />
                                                <TextBlock Grid.Column="1" Text="{Binding FriendlyName, TargetNullValue=Unknown, FallbackValue=Unknown}" Foreground="#FFA6ADC8" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="2" Text="{Binding DriverProvider, TargetNullValue=Unknown, FallbackValue=Unknown}" Foreground="#FFA6ADC8" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="3" Text="{Binding DriverVersion, TargetNullValue=Unknown, FallbackValue=Unknown}" Foreground="#FFA6ADC8" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="4" Text="{Binding DriverDate, TargetNullValue=Unknown, FallbackValue=Unknown}" Foreground="#FFA6ADC8" FontSize="12" TextTrimming="CharacterEllipsis" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="Findings" Style="{StaticResource SectionHeader}" Margin="0,0,0,6" />
                            <ItemsControl ItemsSource="{Binding Findings}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FF313244" CornerRadius="6" Padding="12" Margin="0,4">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <TextBlock Text="{Binding Severity, Converter={StaticResource SeverityToGlyph}}"
                                                               FontSize="12"
                                                               Foreground="#FFCDD6F4"
                                                               Margin="0,0,8,0"
                                                               VerticalAlignment="Center" />
                                                    <Border Background="{Binding Severity, Converter={StaticResource SeverityToColor}}"
                                                            CornerRadius="3" Padding="8,2" Margin="0,0,8,0">
                                                        <TextBlock Text="{Binding Severity}"
                                                                   FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="White" />
                                                    </Border>
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Foreground="#FFCDD6F4"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding Summary}"
                                                           FontSize="12"
                                                           Foreground="#FFA6ADC8"
                                                           TextWrapping="Wrap"
                                                           Margin="0,0,0,4" />
                                                <TextBlock FontSize="12" Foreground="#FF89B4FA" TextWrapping="Wrap">
                                                    <Run FontWeight="SemiBold" Text="Suggestion: " />
                                                    <Run Text="{Binding SuggestedAction, Mode=OneWay}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCard}">
                        <Expander Header="Details (Collector Timing)" Foreground="#FFCDD6F4">
                            <ItemsControl ItemsSource="{Binding CollectorDetails}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="180" />
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding CollectorName}" Foreground="#FFCDD6F4" FontSize="12" />
                                            <TextBlock Grid.Column="1" Text="{Binding Status}" Foreground="#FFA6ADC8" FontSize="12" />
                                            <TextBlock Grid.Column="2" Text="{Binding DurationMs, StringFormat={}{0} ms}" Foreground="#FFA6ADC8" FontSize="12" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </Border>

                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="Snapshot Compare" Style="{StaticResource SectionHeader}" Margin="0,0,0,6" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Content="Compare Snapshots"
                                        Command="{Binding CompareSnapshotsCommand}"
                                        Style="{StaticResource ActionButton}"
                                        Background="#FF45475A"
                                        Foreground="#FFCDD6F4"
                                        Margin="0,0,8,0" />
                                <Button Content="Export Compare Report"
                                        Command="{Binding ExportCompareReportCommand}"
                                        Style="{StaticResource ActionButton}"
                                        Background="#FF45475A"
                                        Foreground="#FFCDD6F4" />
                            </StackPanel>
                            <TextBlock Text="What changed:"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#FFCDD6F4"
                                       Margin="0,0,0,4" />
                            <ItemsControl ItemsSource="{Binding CompareChanges}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   FontSize="12"
                                                   Foreground="#FFA6ADC8"
                                                   TextWrapping="Wrap"
                                                   Margin="0,2,0,2" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Bottom buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <CheckBox Content="Redact personal identifiers (recommended for sharing)"
                          IsChecked="{Binding RedactPersonalIdentifiers}"
                          Foreground="#FFA6ADC8"
                          VerticalAlignment="Center"
                          Margin="0,0,16,0" />
                <Button Content="Back"
                        Command="{Binding BackToHomeCommand}"
                        Style="{StaticResource ActionButton}"
                        Background="#FF45475A"
                        Foreground="#FFCDD6F4"
                        Margin="0,0,8,0" />
                <Button Content="Open Output Folder"
                        Command="{Binding OpenOutputFolderCommand}"
                        Style="{StaticResource ActionButton}"
                        Background="#FF45475A"
                        Foreground="#FFCDD6F4"
                        Margin="0,0,8,0" />
                <Button Content="Export JSON"
                        Command="{Binding ExportJsonCommand}"
                        Style="{StaticResource ActionButton}" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
